<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Ulrichb-officiel - Des conseils à la comédie">
    <meta name="theme-color" content="#6f42c1">
    <title>Ulrichb-officiel | Conseils à la Comédie</title>
    <link rel="stylesheet" href="css/styles.css">
</head>
<body>
    <!-- Navigation -->
    <nav class="navbar">
        <div class="container">
            <div class="navbar-brand">
                <h1>🎭 Ulrichb-officiel</h1>
            </div>
            <ul class="navbar-menu">
                <li><a href="index.html" class="active">Accueil</a></li>
                <li><a href="pages/conseils.html">Conseils</a></li>
                <li><a href="pages/ressources.html">Ressources</a></li>
                <li><a href="pages/videos.html">Vidéos</a></li>
                <li><a href="pages/contact.html">Contact</a></li>
            </ul>
        </div>
    </nav>

    <!-- En-tête principal -->
    <header class="hero">
        <div class="container">
            <h1>Bienvenue sur Ulrichb-officiel</h1>
            <p class="subtitle">Maîtrisez l'art de la comédie avec nos conseils pratiques</p>
            <a href="pages/conseils.html" class="cta-button">Découvrir les conseils</a>
        </div>
    </header>

    <!-- Contenu principal -->
    <main class="container">
        <!-- Sections principales -->
        <section class="features">
            <div class="feature-card">
                <div class="feature-icon">📚</div>
                <h3>Conseils Pratiques</h3>
                <p>Découvrez des techniques éprouvées pour améliorer votre présence sur scène et votre sens de l'humour.</p>
            </div>
            <div class="feature-card">
                <div class="feature-icon">📹</div>
                <h3>Vidéos Tutorielles</h3>
                <p>Regardez nos vidéos de haute qualité et apprenez directement des experts en comédie.</p>
            </div>
            <div class="feature-card">
                <div class="feature-icon">📖</div>
                <h3>Ressources</h3>
                <p>Accédez à des ressources, références et inspirations pour progresser dans votre parcours comique.</p>
            </div>
        </section>

        <!-- Section d'introduction -->
        <section class="intro">
            <h2>À propos</h2>
            <p>
                Ulrichb-officiel est une plateforme dédiée à l'apprentissage et au perfectionnement de la comédie. 
                Que vous soyez débutant ou comédien expérimenté, vous trouverez ici les outils et conseils 
                nécessaires pour développer votre talent et votre confiance sur scène.
            </p>
        </section>

        <!-- Derniers conseils -->
        <section class="latest-tips">
            <h2>Derniers Conseils</h2>
            <div id="tips-container" class="tips-grid">
                <!-- Chargé dynamiquement via JavaScript -->
            </div>
        </section>
    </main>

    <!-- Pied de page -->
    <footer class="footer">
        <div class="container">
            <p>&copy; 2026 Ulrichb-officiel. Tous droits réservés.</p>
            <p>Créé avec ❤️ par Ulrich B.</p>
        </div>
    </footer>

    <script src="js/script.js"></script>
    <script src="js/videos.js"></script>
</body>
</html>